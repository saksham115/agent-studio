# === Database ===
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agent_studio

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === LLM ===
# Switches the primary LLM backend. "pellet" routes through the Pellet
# inference gateway (Llama 3.3 70B); "anthropic" calls the Anthropic API
# directly (Claude). Leaving it unset = pellet.
LLM_PROVIDER=pellet

# --- Pellet (active when LLM_PROVIDER=pellet) ---
PELLET_API_KEY=
PELLET_BASE_URL=https://getpellet.io/v1

# --- Anthropic (active when LLM_PROVIDER=anthropic) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# === Embeddings ===
VOYAGE_API_KEY=pa-xxxxxxxxxxxxxxxxxxxxx

# === Auth (must match frontend AUTH_SECRET) ===
AUTH_SECRET=your-nextauth-secret-at-least-32-characters-long
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# === S3/MinIO (document storage) ===
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=agent-studio-uploads
AWS_REGION=ap-south-1

# === Voice (Plivo + Sarvam) ===
# India-region Plivo account required (separate from US — KYC: COI/Udyam + GST).
SARVAM_API_KEY=
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
# Set after running scripts/setup_plivo_app.py once.
PLIVO_APPLICATION_ID=
# Set to true ONLY after the demo confirms signature verification works behind
# ngrok. Default false ships in log-only mode (logs failures, does not reject).
PLIVO_VERIFY_SIGNATURES=false
# Optional override; auto-derived from PUBLIC_API_URL if blank.
PUBLIC_WS_URL=

# === WhatsApp (Gupshup) ===
GUPSHUP_API_KEY=
GUPSHUP_APP_NAME=
GUPSHUP_SOURCE_PHONE=

# === CORS ===
CORS_ORIGINS=["http://localhost:3000"]

# === End-user memory (mem0 + Voyage embeddings) ===
# mem0's pgvector backend opens its own psycopg connection — these are
# separate from DATABASE_URL above. Default values match docker-compose's
# local Postgres; override only if mem0 should target a different DB.
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres
PG_DATABASE=agent_studio

# Phone-number normalization region. Indian numbers without a country code
# parse correctly when this is "IN".
DEFAULT_PHONE_REGION=IN

# mem0 pings telemetry on first call by default. We opt out.
MEM0_TELEMETRY=False
# OPENAI_API_KEY (already set above) powers mem0's embedder
# (text-embedding-3-small, 1536-dim). KB stays on Voyage; this key is
# memory-only and required for facts to land in agent_studio_memory.
