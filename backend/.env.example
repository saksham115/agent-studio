# === Database ===
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agent_studio

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === LLM ===
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# === Embeddings ===
VOYAGE_API_KEY=pa-xxxxxxxxxxxxxxxxxxxxx

# === Auth (must match frontend AUTH_SECRET) ===
AUTH_SECRET=your-nextauth-secret-at-least-32-characters-long
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# === S3/MinIO (document storage) ===
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=agent-studio-uploads
AWS_REGION=ap-south-1

# === Voice (Exotel + Sarvam) ===
SARVAM_API_KEY=
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
EXOTEL_SID=
EXOTEL_SUBDOMAIN=

# === WhatsApp (Gupshup) ===
GUPSHUP_API_KEY=
GUPSHUP_APP_NAME=
GUPSHUP_SOURCE_PHONE=

# === CORS ===
CORS_ORIGINS=["http://localhost:3000"]
